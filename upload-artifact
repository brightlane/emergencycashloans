name: Build and Deploy

on:
  push:
    branches:
      - main

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      # Checkout the code from the repository
      - name: Checkout code
        uses: actions/checkout@v3  # This is still valid

      # Set up Node.js environment
      - name: Set up Node.js
        uses: actions/setup-node@v3  # No deprecation, this is good

      # Install dependencies and build the app
      - name: Install dependencies
        run: npm install

      - name: Build the app
        run: npm run build

      # Upload the build artifacts (updated to v4)
      - name: Upload build artifacts
        uses: actions/upload-artifact@v4  # Updated from v3 to v4
        with:
          name: build-artifacts
          path: ./build

      # Deploy your app (or another step after build)
      - name: Deploy
        run: ./deploy.sh

      # You could add more steps depending on your workflow...
