name: SEO Debug + Generator (Stable)

permissions:
  contents: write

on:
  workflow_dispatch:
  push:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      # =========================
      # 1. CHECKOUT
      # =========================
      - name: Checkout repo
        uses: actions/checkout@v4

      # =========================
      # 2. NODE SETUP (IMPORTANT)
      # =========================
      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: 20

      # =========================
      # 3. SAFE REPO INSPECTION (NO BROKEN CHARACTERS)
      # =========================
      - name: Show repo structure
        run: |
          echo "=== ROOT FILES ==="
          ls

          echo "=== DETAILED LIST ==="
          ls -la || true

          echo "=== WORKING DIR ==="
          pwd

      # =========================
      # 4. CHECK GENERATOR FILE EXISTS
      # =========================
      - name: Check keyword generator
        run: |
          if [ -f keyword-generator.js ]; then
            echo "✔ keyword-generator.js found"
          else
            echo "❌ keyword-generator.js missing"
            exit 1
          fi

      # =========================
      # 5. RUN GENERATOR SAFELY
      # =========================
      - name: Run keyword generator
        run: |
          node keyword-generator.js || {
            echo "❌ Generator failed"
            exit 1
          }

      # =========================
      # 6. VERIFY OUTPUT
      # =========================
      - name: Check output file
        run: |
          if [ -f keywords.txt ]; then
            echo "✔ keywords.txt generated"
            head -20 keywords.txt
          else
            echo "❌ keywords.txt NOT created"
            exit 1
          fi

      # =========================
      # 7. COMMIT RESULTS
      # =========================
      - name: Commit generated keywords
        run: |
          git config user.name "github-actions"
          git config user.email "actions@github.com"

          git add keywords.txt

          git diff --cached --quiet && echo "No changes to commit" && exit 0

          git commit -m "Auto-generated SEO keywords"
          git push
